    local allObjs = workspace:GetDescendants()
    for i = 1, #allObjs do CheckObject(allObjs[i]) if i % 1000 == 0 then task.wait() end end
end)
table.insert(connections, workspace.DescendantAdded:Connect(CheckObject))

